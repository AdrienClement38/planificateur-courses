datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id           Int      @id @default(autoincrement())
  name         String                        // Nom normalisé (ex: "filet de poulet")
  brand        String?                       // Marque (ex: "Le Gaulois")
  drive        String                        // "leclerc" | "carrefour" | etc.
  store_id     String?                       // Identifiant magasin (ex: "echirolles-comboire")
  price_ttc    Float                         // Prix TTC unitaire
  unit         String?                       // "kg", "pièce", "L", "paquet"
  quantity     String?                       // "720g", "2kg", "x6"
  category     String                        // Catégorie (ex: "Viandes & Poissons")
  search_url   String?                       // URL de recherche sur le drive
  last_updated DateTime @default(now())
  source           String   @default("manual")   // "manual" | "scrape" | "invoice"
  is_favorite      Boolean  @default(false)      // Articles obligatoires pour toutes les commandes
  is_banned         Boolean  @default(false)      // Articles à ignorer dans les menus
  needs_scraping   Boolean  @default(false)      // Marqueur pour rafraîchir le prix plus tard

  @@unique([name, quantity, drive, store_id])
  @@index([name, drive])
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     String @default("admin")
}

model FavoriteStore {
  id        String   @id @default(cuid())
  name      String
  address   String
  url       String   @unique
  drive     String   // "leclerc", "carrefour", etc.
  storeId   String?  // The internal store ID if available
  createdAt DateTime @default(now())
}

model FavoriteMeal {
  id                    String   @id @default(cuid())
  breakfast             String?
  breakfast_ingredients String?  // Par exemple, JSON stringifié ou liste séparée
  lunch                 String?
  lunch_ingredients     String?
  dinner                String?
  dinner_ingredients    String?
  tags                  String?  // JSON or comma separated
  createdAt             DateTime @default(now())
}

model GeminiKey {
  id         String   @id @default(cuid())
  name       String
  key        String   // Encrypted
  isActive   Boolean  @default(true)
  lastStatus String?  // e.g., "200", "429", "503"
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model SavedMealPlan {
  id        String   @id @default(cuid())
  planData  String   // JSON stringified MealPlan
  formData  String   // JSON stringified PlannerFormData
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
